{
  "ssh_connections": [
    {
      "host": "observatory.arpa",
      "username": "kayman",
      "projects": [
        {
          "paths": ["~/git/ironkayman.github.io"]
        },
        {
          "paths": [
            "~/git/research/voiselab/tts/tortoise-local"
          ]
        }
      ]
    }
  ],
  "assistant": {
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:1.5b"
    },
    "version": "2"
  },
