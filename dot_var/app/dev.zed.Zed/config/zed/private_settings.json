  "features": {
    "edit_prediction_provider": "copilot"
  },
  "soft_wrap": "bounded",
  "preferred_line_length": 60,
  "hard_tabs": false,
  "tab_size": 2,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Rosé Pine"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Bearded Icon Theme",
    "dark": "Bearded Icon Theme"
  },
  "base_keymap": "None",

  // LSP
  "auto_install_extensions": {
    "cspell": false
  },
  "languages": {
    "C++": {
      "language_servers": ["!cspell"]
    },
    "C": {
      "language_servers": ["!cspell"]
    },
    "Go": {
      "language_servers": ["!cspell"]
    },
    "Zig": {
      "language_servers": ["!cspell"]
    },
    "JSONC": {
      "language_servers": ["!cspell"]
    },
    "JavaScript": {
      "language_servers": [
        "!cspell",
        "typescript-language-server",
        "!vtsls"
      ]
    },
    "Python": {
      "language_servers": ["!cspell"]
    },
    "Markdown": {
      "language_servers": ["!cspell"]
    },
    "TypeScript": {
      "language_servers": [
        "typescript-language-server",
        "!vtsls",
        "!cspell"
      ]
    },
    "TSX": {
      "language_servers": [
        "typescript-language-server",
        "!vtsls",
        "!cspell"
      ]
    }
  }
}
